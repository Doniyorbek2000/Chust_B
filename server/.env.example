# ADM Bozor server sozlamalari — nusxa oling: cp .env.example .env
# Ishga tushirish: export $(cat .env | xargs) && npm start
# yoki PM2/Docker orqali env sifatida bering.

# --- MAJBURIY (production) ---
NODE_ENV=production
# Tasodifiy maxfiy kalit yarating: openssl rand -hex 32
JWT_SECRET=

# --- Birinchi ishga tushirishda admin yaratish ---
ADMIN_EMAIL=admin@admbozor.uz
ADMIN_PASSWORD=

# --- Ixtiyoriy ---
PORT=4000
# Ruxsat etilgan web originlar (vergul bilan). Panellar shu serverdan berilsa shart emas.
CORS_ORIGINS=https://admbozor.uz
# DB_FILE=/var/lib/admbozor/admbozor.db
# UPLOADS_DIR=/var/lib/admbozor/uploads
# SHIPPING_FEE=15000
# FREE_SHIPPING_FROM=300000
